<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime: allow outbound HTTP to daemon API -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Hardened runtime: allow incoming connections (daemon HTTP server) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Required for AVAudioEngine microphone capture under Hardened Runtime.
         Without this, the kernel denies audio device access even after TCC grants
         the mic dialog — on macOS Tahoe this resets the TCC state, causing the
         permission dialog to reappear on every recording attempt. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
